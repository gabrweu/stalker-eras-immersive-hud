    { key = "reveal_bhs_keep_while_hurt",  def = false, group = "reveals", mcm = { type = "check", val = 1, hint = "era_ihud_bhs_keep_while_hurt" } },
    { key = "reveal_stamina_on_drain",     def = true,  group = "reveals", mcm = { type = "check", val = 1, hint = "era_ihud_stamina_on_drain" } },
    { key = "reveal_radiation_on_present",  def = true,  group = "reveals", mcm = { type = "check", val = 1, hint = "era_ihud_radiation_on_present" } },
