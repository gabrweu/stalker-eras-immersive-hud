    { key = "show_lock_indicator",     def = true,  group = "behavior", mcm = { type = "check", val = 1, hint = "era_ihud_show_lock" } },
    { key = "reveal_during_inventory", def = false, group = "reveals", mcm = { type = "check", val = 1, hint = "era_ihud_reveal_inventory" } },
    { key = "reveal_pda_messages_during_inventory", def = false, group = "reveals", mcm = { type = "check", val = 1, hint = "era_ihud_pda_messages_in_inventory" } },
