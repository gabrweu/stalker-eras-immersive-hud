-- Era's Immersive HUD

local MODE                = z_era_immersive_hud_config.MODE
local KEYS                = z_era_immersive_hud_config.KEYS
local settings_cache      = z_era_immersive_hud_config.DEFAULTS

-- Reveal state. Each is independent; an element shows if any active source asks for it.
local is_hud_showing      = false -- toggled by the hotkey
local is_inventory_open   = false -- set while the inventory / PDA is open
local bhs_reveal_for_time = 0     -- time_global() deadline for the on-damage BHS flash (0 = inactive)

local function mcm_get(key)
    if ui_mcm then
        local setting = ui_mcm.get("era_immersive_hud/" .. key)
        if setting ~= nil then return setting end
    end

    return z_era_immersive_hud_config.DEFAULTS[key]
end

local function reload_settings_cache()
    for key, _ in pairs(settings_cache) do
        settings_cache[key] = mcm_get(key)
    end
end

local function should_display_for_setting_key(element, reveals_on_inventory)
    local mode = settings_cache[element]
    if mode == MODE.SHOW then return true end
    if mode == MODE.HIDE then return false end

    if is_hud_showing then return true end
    if reveals_on_inventory and is_inventory_open and settings_cache.reveal_during_inventory then return true end

    return false
end


---------------------------------------------------------------------------------------------

local BHS_PARTS          = { "head", "torso", "rightarm", "leftarm", "rightleg", "leftleg" }
local BHS_RATIO_SUFFIXES = { "", "_43", "_1610", "_169", "_219", "_2110", "_1612" }

local function build_bhs_static_names()
    local base_names = {
        "body_health_system", "body_health_system_text", "cop_debug", "bhs_garbage",
        "bhs_stamina_bar", "bhs_stamina_bar_bg", "bhs_health_bar",
    }

    for _, part in ipairs(BHS_PARTS) do
        base_names[#base_names + 1] = "bhs_health_" .. part .. "_bar"
        base_names[#base_names + 1] = "bhs_health_" .. part .. "_bar_green"
    end

    local names = {}
    for _, name in ipairs(base_names) do
        for _, suf in ipairs(BHS_RATIO_SUFFIXES) do
            names[#names + 1] = name .. suf
        end
    end

    return names
end

local BHS_STATIC_NAMES = build_bhs_static_names()
local BHS_STATIC_SET = {}
for _, name in ipairs(BHS_STATIC_NAMES) do BHS_STATIC_SET[name] = true end

local function bhs_should_display()
    if bhs_reveal_for_time > 0 then return true end
    return should_display_for_setting_key(KEYS.mode_bhs, true) -- reveals while inventory is open (if setting is enabled)
end

local function set_bhs_visible(visible)
    local hud = get_hud()
    if not hud or not hud.GetCustomStatic then return end

    for _, name in ipairs(BHS_STATIC_NAMES) do
        local st = hud:GetCustomStatic(name)
        if st then
            local wnd = st:wnd()
            if wnd then wnd:Show(visible and true or false) end
        end
    end

    local mg = ActorMenu.get_maingame()
    if mg and mg.m_ui_hud_states then
        mg.m_ui_hud_states.m_ui_psy_bar_show = visible and true or false
    end
end


---------------------------------------------------------------------------------------------

local AMMO_ELEMENTS = { "m_ui_weapon_icon", "m_ui_weapon_cur_ammo", "m_fire_mode" }

local function set_ammo_visible(visible)
    local mg = ActorMenu.get_maingame()
    if not mg or not mg.m_ui_hud_states then return end

    local states = mg.m_ui_hud_states
    for _, name in ipairs(AMMO_ELEMENTS) do
        local ele = states[name]
        if ele then
            local pos = ele:GetWndPos()
            -- Hidden => X off-screen (negative), shown => X on-screen (positive). Idempotent.
            if (not visible and pos.x > 0) or (visible and pos.x < 0) then
                pos.x = -pos.x
                ele:SetWndPos(pos)
            end
        end
    end
end


local PDA_MSGS_OFFSCREEN_Y = 9999
local pda_messages_home_x, pda_messages_home_y = nil, nil

local function set_pda_messages_visible(visible)
    if not (ActorMenu and ActorMenu.get_messages_menu) then return end

    local ok, w = pcall(ActorMenu.get_messages_menu)
    if not (ok and w and w.GetWndPos and w.SetWndPos) then return end

    -- get the home x and y to restore it when re-enabling.
    if not pda_messages_home_y then
        local got, p = pcall(w.GetWndPos, w)
        if not (got and p) then return end
        pda_messages_home_x, pda_messages_home_y = p.x, p.y
    end

    local y = visible and pda_messages_home_y or (pda_messages_home_y + PDA_MSGS_OFFSCREEN_Y)
    pcall(w.SetWndPos, w, vector2():set(pda_messages_home_x, y))
end


-- "notify_icon"
local NOTIFY_OFFSCREEN_X = 9999
local pda_notification_icon_home_x = nil -- engine's on-screen X, captured the first time we see it placed

local function set_pda_notification_visible(visible)
    local hud = get_hud()
    if not hud or not hud.GetCustomStatic then return end

    local cs = hud:GetCustomStatic("notify_icon")
    if not cs then return end -- no notification icon active right now

    local wnd = cs:wnd()
    if not wnd then return end

    local pos = wnd:GetWndPos()

    if pos.x < NOTIFY_OFFSCREEN_X then
        pda_notification_icon_home_x = pos.x
    end

    pos.x = (visible and pda_notification_icon_home_x) or NOTIFY_OFFSCREEN_X
    wnd:SetWndPos(pos)
end

-- Hook the engine's notification setter so a freshly-created icon immediately obeys our state.
if actor_menu and actor_menu.set_notification and not actor_menu.__era_ihud_notif_hooked then
    local original_set_notification = actor_menu.set_notification

    actor_menu.set_notification = function(typ, texture, tm, snd)
        original_set_notification(typ, texture, tm, snd)
        set_pda_notification_visible(should_display_for_setting_key(KEYS.mode_pda_notification))
    end

    actor_menu.__era_ihud_notif_hooked = true
end


local STATUS_OFFSCREEN_Y = 9999
local status_icons_home_x, status_icons_home_y = nil, nil

local function set_status_visible(visible)
    if not actor_status then return end

    local hud = actor_status.HUD
    if not (hud and hud.GetWndPos and hud.SetWndPos) then return end -- dialog not built yet

    if not status_icons_home_y then                                  -- capture home BEFORE the first move, or we can't restore it
        local ok, p = pcall(hud.GetWndPos, hud)
        if not (ok and p) then return end
        status_icons_home_x, status_icons_home_y = p.x, p.y
    end

    local y = visible and status_icons_home_y or (status_icons_home_y + STATUS_OFFSCREEN_Y)
    pcall(hud.SetWndPos, hud, vector2():set(status_icons_home_x, y))
end


---------------------------------------------------------------------------------------------
-- Other-mod-overlays and HUDs catch-all. EXPERIMENTAL.
-- there are static overlay names and dynamically added HUDs. There might be other ways to add UI, need to test with more mods.
-- for ones we actually know there's KNOWN_OVERLAY_DIALOGS.
-- heavy Claude used here; needs more testing and reviewing.

local tracked_overlay_dialogs = {}    -- set: registered dialog -> true
local tracked_overlay_statics = {}    -- set: custom-static name -> true
local overlay_hook_installed  = false -- process-level: install the metatable hook only once

local KNOWN_OVERLAY_DIALOGS   = {
    -- function() return mag_hud and mag_hud.HUD end,
}

local function is_excluded_overlay_static(name)
    return BHS_STATIC_SET[name] or name == "notify_icon"
end

local function is_excluded_overlay_dialog(dlg)
    -- actor_status.HUD is the status-icons dialog, driven by set_status_visible.
    return actor_status ~= nil and actor_status.HUD ~= nil and rawequal(dlg, actor_status.HUD)
end

-- We only ever un-hide what we actually hid, so revealing overlays can't force-show a HUD a mod
-- deliberately kept hidden. These sets remember exactly what the catch-all parked.
local overlay_hidden_dialogs = {} -- set: dialog we hid -> true
local overlay_hidden_statics = {} -- set: static name we hid -> true

local function hide_overlay_dialog(dlg)
    if dlg and dlg.Show and not is_excluded_overlay_dialog(dlg) then
        pcall(dlg.Show, dlg, false)
        overlay_hidden_dialogs[dlg] = true
    end
end

local function hide_overlay_static(name)
    if is_excluded_overlay_static(name) then return end
    local hud = get_hud()
    if not (hud and hud.GetCustomStatic) then return end
    local cs = hud:GetCustomStatic(name)
    local wnd = cs and cs:wnd()
    if wnd then
        pcall(wnd.Show, wnd, false)
        overlay_hidden_statics[name] = true
    end
end

local function restore_hidden_overlays()
    for dlg, _ in pairs(overlay_hidden_dialogs) do
        if dlg.Show then pcall(dlg.Show, dlg, true) end
    end
    overlay_hidden_dialogs = {}

    local hud = get_hud()
    for name, _ in pairs(overlay_hidden_statics) do
        if hud and hud.GetCustomStatic then
            local cs = hud:GetCustomStatic(name)
            local wnd = cs and cs:wnd()
            if wnd then pcall(wnd.Show, wnd, true) end
        end
    end
    overlay_hidden_statics = {}
end

local function set_overlay_visible(visible)
    if visible then
        restore_hidden_overlays() -- un-hide only what we hid; leave mod-controlled state alone
        return
    end

    local seen = {}
    for dlg, _ in pairs(tracked_overlay_dialogs) do
        if not seen[dlg] then
            seen[dlg] = true
            hide_overlay_dialog(dlg)
        end
    end
    for _, resolver in ipairs(KNOWN_OVERLAY_DIALOGS) do
        local ok, dlg = pcall(resolver)
        if ok and dlg and not seen[dlg] then
            seen[dlg] = true
            hide_overlay_dialog(dlg)
        end
    end
    for name, _ in pairs(tracked_overlay_statics) do
        hide_overlay_static(name)
    end
end

local function overlays_should_display()
    return should_display_for_setting_key(KEYS.mode_other_mods)
end

-- Intercept the HUD's dialog/static registration so we observe everything mods add. Installed once
-- per process, the first time get_hud() is valid; handles both table- and function-typed __index.
local function install_overlay_hook()
    if overlay_hook_installed then return end

    local hud = get_hud()
    if not hud then return end
    local mt = getmetatable(hud)
    local idx = mt and mt.__index
    if not idx then return end

    local function on_add_dialog(_self, dlg)
        if dlg and not is_excluded_overlay_dialog(dlg) then
            tracked_overlay_dialogs[dlg] = true
            if not overlays_should_display() then hide_overlay_dialog(dlg) end
        end
    end
    local function on_remove_dialog(_self, dlg)
        if dlg then
            tracked_overlay_dialogs[dlg] = nil
            overlay_hidden_dialogs[dlg] = nil
        end
    end
    local function on_add_static(_self, name)
        if type(name) == "string" and not is_excluded_overlay_static(name) then
            tracked_overlay_statics[name] = true
            if not overlays_should_display() then hide_overlay_static(name) end
        end
    end
    local function on_remove_static(_self, name)
        if type(name) == "string" then
            tracked_overlay_statics[name] = nil
            overlay_hidden_statics[name] = nil
        end
    end

    if type(idx) == "table" then
        -- Clean path: wrap the four methods directly in the shared method table (no per-call cost).
        local function wrap(method_name, observer)
            local original = idx[method_name]
            if type(original) ~= "function" then return end
            idx[method_name] = function(self, a, b)
                local r = original(self, a, b)
                observer(self, a)
                return r
            end
        end
        wrap("AddDialogToRender", on_add_dialog)
        wrap("RemoveDialogToRender", on_remove_dialog)
        wrap("AddCustomStatic", on_add_static)
        wrap("RemoveCustomStatic", on_remove_static)
        overlay_hook_installed = true
    elseif type(idx) == "function" then
        -- luabind function __index: front it with a dispatcher returning cached wrapped closures for
        -- our four targets, passing every other method lookup straight through unchanged.
        local original_index = idx
        local observers = {
            AddDialogToRender    = on_add_dialog,
            RemoveDialogToRender = on_remove_dialog,
            AddCustomStatic      = on_add_static,
            RemoveCustomStatic   = on_remove_static,
        }
        local wrapped_cache = {}
        mt.__index = function(self, key)
            local observer = observers[key]
            if not observer then return original_index(self, key) end
            local cached = wrapped_cache[key]
            if not cached then
                cached = function(s, a, b)
                    local r = original_index(s, key)(s, a, b)
                    observer(s, a)
                    return r
                end
                wrapped_cache[key] = cached
            end
            return cached
        end
        overlay_hook_installed = true
    end
end


---------------------------------------------------------------------------------------------

local function set_minimap_visible(visible)
    local mg = ActorMenu.get_maingame()
    if not mg or not mg.UIZoneMap then return end

    mg.UIZoneMap.disabled = not visible
    -- not sure UIMotion is needed tbf
    mg.UIMotionIcon:Show(visible and true or false)
end

local function apply_hud_visibility_logic()
    if not (db and db.actor) then return end

    set_minimap_visible(should_display_for_setting_key(KEYS.mode_minimap))
    set_bhs_visible(bhs_should_display())
    set_ammo_visible(should_display_for_setting_key(KEYS.mode_ammo))
    set_status_visible(should_display_for_setting_key(KEYS.mode_statuses, true))
    set_pda_messages_visible(should_display_for_setting_key(KEYS.mode_pda_messages))
    set_pda_notification_visible(should_display_for_setting_key(KEYS.mode_pda_notification))
    set_overlay_visible(should_display_for_setting_key(KEYS.mode_other_mods))
end


---------------------------------------------------------------------------------------------

local function actor_menu_on_mode_changed_callback(mode, last_mode)
    if mode == 1 then
        is_inventory_open = true
        apply_hud_visibility_logic()
    elseif last_mode == 1 then
        is_inventory_open = false
        apply_hud_visibility_logic()
    end
end

local function actor_on_before_hit_callback(shit)
    if not settings_cache.reveal_bhs_on_damage then return end
    if not (shit and shit.power and shit.power > 0) then return end -- ignore 0-damage hits

    local duration = (settings_cache.reveal_duration or 5) * 1000
    bhs_reveal_for_time = time_global() + duration
    set_bhs_visible(true)
end

local applied_initial = false

local function actor_on_update_callback()
    if not applied_initial and db and db.actor then
        applied_initial = true
        install_overlay_hook() -- get_hud() is valid by now; observe mod HUD registrations
        apply_hud_visibility_logic()
    end

    if bhs_reveal_for_time == 0 then return end
    if time_global() < bhs_reveal_for_time then return end

    bhs_reveal_for_time = 0
    set_bhs_visible(bhs_should_display())
end

local function on_key_press_callback(dik)
    if not (db and db.actor) then return end
    if level.main_input_receiver and level.main_input_receiver() then return end
    if not settings_cache.toggle_key or settings_cache.toggle_key == 0 then return end
    if dik ~= settings_cache.toggle_key then return end

    local function toggle_modifier_held(mod_id)
        -- 0=none 1=shift 2=ctrl 3=alt
        if not mod_id or mod_id == 0 then return true end

        if ui_mcm and ui_mcm.get_mod_key then
            return ui_mcm.get_mod_key(mod_id) and true or false
        end

        return true
    end

    if not toggle_modifier_held(settings_cache.toggle_modifier) then return end

    is_hud_showing = not is_hud_showing
    apply_hud_visibility_logic()
end

local function on_option_change_callback()
    reload_settings_cache()
    apply_hud_visibility_logic()
end

local function on_news_received_callback()
    if not (db and db.actor) then return end
    set_pda_messages_visible(should_display_for_setting_key(KEYS.mode_pda_messages))
end

function on_game_start()
    reload_settings_cache()

    is_hud_showing                           = false
    is_inventory_open                        = false
    bhs_reveal_for_time                      = 0
    applied_initial                          = false

    pda_notification_icon_home_x             = nil
    pda_messages_home_x, pda_messages_home_y = nil, nil
    status_icons_home_x, status_icons_home_y = nil, nil

    -- Drop stale dialog instances from a prior load; mods re-register their HUDs after load and the
    -- metatable hook (installed once, kept across loads) re-tracks them.
    tracked_overlay_dialogs                  = {}
    tracked_overlay_statics                  = {}
    overlay_hidden_dialogs                   = {}
    overlay_hidden_statics                   = {}

    RegisterScriptCallback("on_key_press", on_key_press_callback)
    RegisterScriptCallback("on_option_change", on_option_change_callback)
    RegisterScriptCallback("actor_on_update", actor_on_update_callback)
    RegisterScriptCallback("actor_on_before_hit", actor_on_before_hit_callback)
    RegisterScriptCallback("ActorMenu_on_mode_changed", actor_menu_on_mode_changed_callback)
    RegisterScriptCallback("on_news_received", on_news_received_callback)
end
