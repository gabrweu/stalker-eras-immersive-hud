-- Era's Immersive HUD
--
-- CONTENTS
--   1. Imports & constants
--   2. Reveal state              -- module-level mutable state, all reset in on_game_start().
--   3. Settings helpers          -- mcm_get / reload_settings_cache / should_display_for_setting_key.
--   4. BHS & stamina integration -- the complex part for hiding and such.
--   5. Other HUD element setters -- ammo, PDA messages/notify, status, minimap, companion.
--   6. Lock overlay              -- our own padlock-icon UI (UIEraIHudLock).
--   7. Central dispatch          -- apply_hud_visibility_logic.
--   8. Input & reveal triggers   -- keys, per-frame update, inventory/damage/stamina.
--   9. Lifecycle & callbacks     -- on_game_start and the callback registrations.

-- ===========================================================================
-- 1. Imports & constants
-- ===========================================================================

local MODE                               = z_era_immersive_hud_config.MODE
local KEYS                               = z_era_immersive_hud_config.KEYS
local settings_cache                     = z_era_immersive_hud_config.DEFAULTS

local OFFSCREEN_OFFSET                   = 9999
local OFFSCREEN_MIN_COORD                = OFFSCREEN_OFFSET / 2

local BHS_REASSERT_INTERVAL              = 250

-- TODO: make these configurable by the user maybe?
local DAMAGE_PSY_DROP                    = 0.001 -- min psy drop counted as a hit (tunable; real hits are larger)
local DAMAGE_PSY_RECOVERED_AT            = 0.999 -- health/psy at/above this = "fully recovered"

local STAMINA_REVEAL_BELOW               = 0.9
local STAMINA_REFILLED_AT                = 0.99

local RADIATION_REVEAL_ABOVE             = 0 -- db.actor.radiation above this counts as "irradiated"

-- ===========================================================================
-- 2. Reveal state  (module-level mutable state -- all reset in on_game_start)
-- ===========================================================================

local is_hud_showing                     = false -- toggled by the hotkey
local is_hud_pinned                      = false -- the HUD is pinned on via long-press (drives the "locked" indicator)
local is_stamina_showing                 = false
local is_inventory_open                  = false -- set while the inventory / PDA is open

local key_down_time                      = 0     -- time_global() when the toggle key went down (0 = no press pending). Used for locking the HUD in place.
local long_press_fired                   = false -- the hold-to-pin already triggered for the current press.
local bhs_reveal_on_damage_timer         = 0     -- time_global() deadline for the on-damage BHS flash (0 = inactive).
local full_hud_timer                     = 0     -- time_global() deadline for the auto-hide-after-showing timer (0 = inactive).
local ammo_fired_timer                   = 0     -- time_global() deadline for the post-fire ammo reveal (0 = inactive).

local is_hud_showing_due_to_actor_damage = false -- sticky on-damage reveal (kept while the actor is hurt).
local last_actor_health                  = nil   -- previous frame's actor health, for detecting real damage (a health drop)
local last_actor_psy_health              = nil   -- previous frame's psy health, for detecting psy damage (a drop)


local status_reveal_timer = 0                  -- time_global() deadline for the new-status-effect reveal (0 = inactive)
local last_status_set     = nil                -- previous active-indicator name set; nil = baseline not taken yet
local status_check_next   = 0                  -- throttle for the new-status scan

local bhs_reassert_next   = 0

-- ===========================================================================
-- 3. Settings helpers
-- ===========================================================================

local function mcm_get(key)
    if ui_mcm then
        local setting = ui_mcm.get("era_immersive_hud/" .. key)
        if setting ~= nil then return setting end
    end

    return z_era_immersive_hud_config.DEFAULTS[key]
end

local function reload_settings_cache()
    for key, _ in pairs(settings_cache) do
        settings_cache[key] = mcm_get(key)
    end
end

local function should_display_for_setting_key(element, inventory_reveal_key)
    local mode = settings_cache[element]
    if mode == MODE.SHOW then return true end
    if mode == MODE.HIDE then return false end

    if is_hud_showing then return true end
    if inventory_reveal_key and is_inventory_open and settings_cache[inventory_reveal_key] then return true end

    return false
end


-- ===========================================================================
-- 4. BHS & stamina integration  (the complex part -- see CLAUDE.md)
-- ===========================================================================

-- TODO: figure out if we can generalize these, or catch all of them elsewhere as a callback instead of iterating through all.
local BHS_PARTS          = { "head", "torso", "rightarm", "leftarm", "rightleg", "leftleg" }
local BHS_RATIO_SUFFIXES = { "", "_43", "_1610", "_169", "_219", "_2110", "_1612" }

local function build_bhs_base_names()
    local base_names = {
        "body_health_system", "body_health_system_text", "cop_debug", "bhs_garbage",
        "bhs_stamina_bar", "bhs_stamina_bar_bg",
        "bhs_health_bar", "bhs_health_bar_bg",
    }

    for _, part in ipairs(BHS_PARTS) do
        base_names[#base_names + 1] = "bhs_health_" .. part .. "_bar"
        base_names[#base_names + 1] = "bhs_health_" .. part .. "_bar_bg" -- minimal bg (mode 1)
        base_names[#base_names + 1] = "bhs_health_" .. part .. "_bar_green"
    end

    return base_names
end

local BHS_BASE_NAMES = build_bhs_base_names()

local BHS_NAMES_BY_SUFFIX = {}
for _, suf in ipairs(BHS_RATIO_SUFFIXES) do
    local t = {}
    for _, base in ipairs(BHS_BASE_NAMES) do t[#t + 1] = base .. suf end
    BHS_NAMES_BY_SUFFIX[suf] = t
end

local bhs_active_suffix = nil -- locked once a variant resolves; narrows the scan

local function damage_reveal_active()
    return bhs_reveal_on_damage_timer > 0 or is_hud_showing_due_to_actor_damage
end

local function bhs_should_display()
    if damage_reveal_active() then return true end
    return should_display_for_setting_key(KEYS.mode_bhs, KEYS.reveal_during_inventory) -- reveals while inventory is open (if setting is enabled)
end

local function get_actor_psy_health()
    if arszi_psy and arszi_psy.get_psy_health then return arszi_psy.get_psy_health() end
    return db.actor.psy_health -- stock Anomaly. Needs testing without GAMMA
end

local function set_bhs_visible(visible)
    local hud = get_hud()
    if not hud or not hud.GetCustomStatic then return end

    local show = visible and true or false

    if bhs_active_suffix then
        local names = BHS_NAMES_BY_SUFFIX[bhs_active_suffix]
        local found = 0
        for i = 1, #names do
            local st = hud:GetCustomStatic(names[i])
            if st then
                found = found + 1
                local wnd = st:wnd()
                if wnd then wnd:Show(show) end
            end
        end
        -- Variant stopped resolving (e.g. resolution changed) -- re-detect next call.
        if found == 0 then bhs_active_suffix = nil end
    else
        -- Not locked yet (the few frames after load before BHS builds its statics):
        -- scan every variant and lock onto the first suffix that resolves anything.
        for _, suf in ipairs(BHS_RATIO_SUFFIXES) do
            local names   = BHS_NAMES_BY_SUFFIX[suf]
            local matched = false
            for i = 1, #names do
                local st = hud:GetCustomStatic(names[i])
                if st then
                    matched = true
                    local wnd = st:wnd()
                    if wnd then wnd:Show(show) end
                end
            end
            if matched and not bhs_active_suffix then bhs_active_suffix = suf end
        end
    end

    local mg = ActorMenu.get_maingame()
    if mg and mg.m_ui_hud_states then
        mg.m_ui_hud_states.m_ui_psy_bar_show = show
    end
end

-- BHS owns its custom statics and re-shows them on its own lifecycle (and DART on_dart_post_refresh rebuild).
local BHS_PROBE_BASES = { "body_health_system", "body_health_system_text", "bhs_health_bar" }

local function bhs_looks_visible()
    local hud = get_hud()
    if not hud or not hud.GetCustomStatic then return false end

    for _, base in ipairs(BHS_PROBE_BASES) do
        for _, suf in ipairs(BHS_RATIO_SUFFIXES) do
            local st = hud:GetCustomStatic(base .. suf)
            if st then
                local wnd = st:wnd()
                if wnd and wnd.IsShown and wnd:IsShown() then return true end
            end
        end
    end

    return false
end

-- True only in BHS's highest-info picture mode: the body_health_system panel static is added
-- only when show_hud_type == 2 (mode 1 shows bars without it). Used to gate the radiation
-- trefoil icon so it appears only with the full panel. Cheap: the active suffix is locked.
local function bhs_full_panel_shown()
    local hud = get_hud()
    if not hud or not hud.GetCustomStatic then return false end

    local suffixes = bhs_active_suffix and { bhs_active_suffix } or BHS_RATIO_SUFFIXES
    for _, suf in ipairs(suffixes) do
        local st = hud:GetCustomStatic("body_health_system" .. suf)
        if st then
            local wnd = st:wnd()
            if wnd and wnd.IsShown and wnd:IsShown() then return true end
        end
    end

    return false
end

-- Split so the background slot can be hidden independently of the fill (the "simplify
-- auto-revealed bars" toggle). set_stamina_visible is only ever called for the standalone
-- drain-reveal (always automatic), so the toggle can gate the bg here unconditionally.
local STAMINA_FILL_NAMES = {}
local STAMINA_BG_NAMES   = {}
for _, suf in ipairs(BHS_RATIO_SUFFIXES) do
    STAMINA_FILL_NAMES[#STAMINA_FILL_NAMES + 1] = "bhs_stamina_bar" .. suf
    STAMINA_BG_NAMES[#STAMINA_BG_NAMES + 1]     = "bhs_stamina_bar_bg" .. suf
end

local function show_statics(names, show)
    local hud = get_hud()
    if not hud or not hud.GetCustomStatic then return end

    for _, name in ipairs(names) do
        local st = hud:GetCustomStatic(name)
        if st then
            local wnd = st:wnd()
            if wnd then wnd:Show(show and true or false) end
        end
    end
end

local function set_stamina_visible(visible)
    local on = visible and true or false
    show_statics(STAMINA_FILL_NAMES, on)
    show_statics(STAMINA_BG_NAMES, on and not settings_cache.minimal_auto_reveal)
end

local apply_hud_visibility_logic -- forward declaration (defined below)
local pin_hud_from_hotkey        -- forward declaration (defined below)
local apply_radiation            -- forward declaration (defined in the overlay section below)

local function apply_bhs_visibility()
    local bhs_on = bhs_should_display()
    set_bhs_visible(bhs_on)

    if bhs_on then
        is_stamina_showing = false
    elseif is_stamina_showing then
        set_stamina_visible(true) -- set_bhs_visible(false) just hid it; bring our reveal back
    end
end

local function actor_is_hurt()
    return db.actor.health < DAMAGE_PSY_RECOVERED_AT or get_actor_psy_health() < DAMAGE_PSY_RECOVERED_AT
end

local function trigger_bhs_damage_reveal()
    local was_inactive = (bhs_reveal_on_damage_timer == 0)
    bhs_reveal_on_damage_timer = time_global() + (settings_cache.reveal_duration or 5) * 1000
    if settings_cache.reveal_bhs_keep_while_hurt then is_hud_showing_due_to_actor_damage = true end
    if was_inactive then apply_hud_visibility_logic() end
end

local bhs_update_hooked = false

-- Re-hide BHS the same tick it rebuilt, before the frame renders. Runs every frame
-- via the BHS update hook and re-hides unconditionally: BHS rebuilds its statics
-- incrementally on save load, and parts can be shown before bhs_looks_visible()'s
-- probed bases are -- so gating this on that probe lets BHS flash on load. The probe
-- is a sufficient, not necessary, signal, so it must not gate the authoritative
-- re-hide.
local function reassert_bhs_hidden()
    if not bhs_should_display() then apply_bhs_visibility() end
end

-- BHS's HUDUpdate (which builds + animates the bars) is a local function, so it
-- can't be intercepted from outside. Its only external handle is the global
-- actor_on_update, which calls HUDUpdate. Wrap that: run BHS's original (it may
-- build/Show a bar this tick), then immediately re-hide while BHS should be
-- hidden -- same tick, before render -> the grow animation never draws.
local function install_bhs_update_hook()
    if bhs_update_hooked then return end
    if not (zzz_player_injuries and zzz_player_injuries.actor_on_update) then return end
    if zzz_player_injuries.__era_ihud_wrapped then
        bhs_update_hooked = true
        return
    end

    local original = zzz_player_injuries.actor_on_update
    local wrapped = function(...)
        original(...)
        pcall(reassert_bhs_hidden) -- never break BHS's no-per-callback-pcall dispatch
    end

    -- The callback registry keys on the function value and dispatches in
    -- unspecified order, so swap the registered entry (not just the module field)
    -- to guarantee our re-hide runs as part of BHS's own update.
    UnregisterScriptCallback("actor_on_update", original)
    RegisterScriptCallback("actor_on_update", wrapped)
    zzz_player_injuries.actor_on_update    = wrapped -- route DART onPostRefresh through wrapper too
    zzz_player_injuries.__era_ihud_wrapped = true
    bhs_update_hooked                      = true
end

local function update_stamina_reveal()
    if not settings_cache.reveal_stamina_on_drain or bhs_should_display() then
        if is_stamina_showing then
            is_stamina_showing = false
            if not bhs_should_display() then set_stamina_visible(false) end
        end
        return
    end

    -- Reveal whenever stamina drops below the threshold (incl. already-low at load /
    -- zone change); is_stamina_showing provides the hysteresis so it stays shown until
    -- stamina refills to STAMINA_REFILLED_AT.
    local power = db.actor.power
    if not is_stamina_showing then
        if power < STAMINA_REVEAL_BELOW then
            is_stamina_showing = true
            set_stamina_visible(true)
        end
    elseif power >= STAMINA_REFILLED_AT then
        is_stamina_showing = false
        set_stamina_visible(false)
    end
end

-- The radiation infection bar above the stamina bar belongs to the Minimalist HUD
-- ("SidHUD"): a script-drawn dialog (like our lock overlay / axr_companions.HUD), not a
-- BHS custom static. Its only handle is the radhealthwindow static.
local function set_radiation_visible(visible)
    if not (ui_sidhud_mcm and ui_sidhud_mcm.HUD and ui_sidhud_mcm.HUD.radhealthwindow) then return end

    local win = ui_sidhud_mcm.HUD.radhealthwindow
    if win.Show then win:Show(visible and true or false) end
end

local function radiation_should_display()
    -- Explicit HIDE guard: "Always hide" must beat the irradiated reveal below.
    if settings_cache.mode_radiation == MODE.HIDE then return false end
    if should_display_for_setting_key(KEYS.mode_radiation) then return true end -- SHOW, or KEY while hotkey-revealed

    if settings_cache.reveal_radiation_on_present
        and db.actor.radiation and db.actor.radiation > RADIATION_REVEAL_ABOVE then
        return true
    end

    return false
end

-- The radiation status-effect icon (actor_status "Radiation" indicator) and the mSv text
-- layered on it are driven by actor_status.get_radiation(true). install_radiation_icon_hook
-- wraps that so the icon obeys radiation_should_display() too -- keeping the icon in sync with
-- the bar (so "Always hide" hides both). actor_status's slots are positional, so there is no
-- fixed slot to target; gating the functor is the clean lever.
local function install_radiation_icon_hook()
    if not (actor_status and actor_status.get_radiation) then return end
    if actor_status.__era_ihud_rad_hooked then return end

    local original = actor_status.get_radiation
    actor_status.get_radiation = function(visual)
        -- visual=true is the indicator/Msv path; 0 => not active => the slot is skipped.
        -- Non-visual callers (game logic) pass through untouched.
        if visual and not radiation_should_display() then return 0 end
        return original(visual)
    end

    actor_status.__era_ihud_rad_hooked = true
end

local last_radiation_visible = nil -- last applied radiation visibility; nil forces a refresh

-- Per frame: apply_radiation() draws our own bar (bg slot + fill) and keeps SidHUD's hidden,
-- so the fill tracks db.actor.radiation. The status-effect icon updates on actor_status's own
-- ~1s throttle, so on a visibility flip we force one refresh for parity with the bar.
local function update_radiation_reveal()
    apply_radiation()

    local want = radiation_should_display()
    if want ~= last_radiation_visible then
        last_radiation_visible = want
        if actor_status and actor_status.HUD and actor_status.HUD.Update then
            actor_status.HUD:Update(true) -- re-evaluate the radiation indicator now, not in ~1s
        end
    end
end

-- Reveal the status-effect bar briefly when a new status-effect icon appears.
-- actor_status builds a global `indicators` table (states + boosters, incl. ones added
-- by other mods); we replicate its pass logic to know which icons are currently active,
-- then fire the reveal when a name shows up that wasn't active last scan.
local STATUS_CHECK_INTERVAL = 1000

local function status_reveal_active()
    return status_reveal_timer > 0
end

local function compute_active_statuses()
    local set = {}
    if not (actor_status and actor_status.indicators) then return set end

    for name, t in pairs(actor_status.indicators) do
        if t.functor then
            local ok, value = pcall(execute_func, unpack(t.functor))
            if ok and value then
                -- Same test actor_status uses in UIIndicators:Update.
                if (t.typ == "state" and value >= 1 and value <= 4)
                    or (t.typ == "booster") then
                    set[name] = true
                end
            end
        end
    end

    return set
end

local function update_status_reveal()
    if not settings_cache.reveal_statuses_on_new then
        last_status_set = nil -- so re-enabling re-baselines instead of flashing for already-active effects
        return
    end

    local now = time_global()
    if now < status_check_next then return end
    status_check_next = now + STATUS_CHECK_INTERVAL

    local current = compute_active_statuses()
    -- First scan after load (or after the setting was off) only baselines -- don't reveal
    -- for effects already active, same idea as the last_actor_health nil-guard.
    if last_status_set then
        for name in pairs(current) do
            if not last_status_set[name] then
                local was_inactive = (status_reveal_timer == 0)
                status_reveal_timer = now + (settings_cache.reveal_duration or 5) * 1000
                if was_inactive then apply_hud_visibility_logic() end
                break
            end
        end
    end
    last_status_set = current
end


-- ===========================================================================
-- 5. Other HUD element setters  (ammo, PDA messages/notify, status, minimap, companion)
-- ===========================================================================

local AMMO_ELEMENTS = { "m_ui_weapon_icon", "m_ui_weapon_cur_ammo", "m_fire_mode" }

local function set_ammo_visible(visible)
    local mg = ActorMenu.get_maingame()
    if not mg or not mg.m_ui_hud_states then return end

    local states = mg.m_ui_hud_states
    for _, name in ipairs(AMMO_ELEMENTS) do
        local ele = states[name]
        if ele then
            local pos = ele:GetWndPos()
            -- Hidden => X off-screen (negative), shown => X on-screen (positive). Idempotent.
            if (not visible and pos.x > 0) or (visible and pos.x < 0) then
                pos.x = -pos.x
                ele:SetWndPos(pos)
            end
        end
    end
end

-- Resolve ammo/weapon-cluster visibility, mirroring radiation_should_display():
-- "Always hide" wins, then SHOW / hotkey-KEY, then the opt-in reveal sources (OR'd).
-- Only meaningful in KEY mode; SHOW already returned true above.
local function ammo_should_display()
    if settings_cache.mode_ammo == MODE.HIDE then return false end         -- Always hide beats the reveals below
    if should_display_for_setting_key(KEYS.mode_ammo) then return true end -- SHOW, or KEY while hotkey-revealed

    if settings_cache.reveal_ammo_on_fire and ammo_fired_timer > 0 then return true end

    local item = db.actor:active_item()
    if item and IsWeapon(item) then
        if settings_cache.reveal_ammo_weapon_out then return true end
        if settings_cache.reveal_ammo_mag_not_full then
            -- Base mag size from the weapon section. With extended-mag mods the loaded
            -- count can exceed this, so "not full" only triggers once below the base.
            local cap = SYS_GetParam(2, item:section(), "ammo_mag_size")
            if cap and cap > 0 and item:get_ammo_in_magazine() < cap then return true end
        end
    end
    return false
end

-- Per-frame driver: the mag-fill / weapon-out conditions change continuously, so
-- (like radiation) we re-resolve every frame. set_ammo_visible is idempotent.
local function update_ammo_reveal()
    set_ammo_visible(ammo_should_display())
end

local function set_pda_messages_visible(visible)
    if not (ActorMenu and ActorMenu.get_messages_menu) then return end

    local ok, w = pcall(ActorMenu.get_messages_menu)
    if not (ok and w and w.GetWndPos and w.SetWndPos) then return end

    local got, p = pcall(w.GetWndPos, w)
    if not (got and p) then return end

    local parked = p.y >= OFFSCREEN_MIN_COORD

    if visible and parked then             -- un-park; otherwise leave the engine's on-screen placement alone
        pcall(w.SetWndPos, w, vector2():set(p.x, p.y - OFFSCREEN_OFFSET))
    elseif not visible and not parked then -- park off-screen from wherever the engine just placed it
        pcall(w.SetWndPos, w, vector2():set(p.x, p.y + OFFSCREEN_OFFSET))
    end
end


-- "notify_icon"
local function set_pda_notification_visible(visible)
    local hud = get_hud()
    if not hud or not hud.GetCustomStatic then return end

    local cs = hud:GetCustomStatic("notify_icon")
    if not cs then return end -- no notification icon active right now

    local wnd = cs:wnd()
    if not wnd then return end

    local pos = wnd:GetWndPos()
    local parked = pos.x >= OFFSCREEN_MIN_COORD

    if visible and parked then -- un-park; otherwise leave the engine's on-screen placement alone
        pos.x = pos.x - OFFSCREEN_OFFSET
        wnd:SetWndPos(pos)
    elseif not visible and not parked then -- park off-screen from wherever the engine placed it
        pos.x = pos.x + OFFSCREEN_OFFSET
        wnd:SetWndPos(pos)
    end
end

if actor_menu and actor_menu.set_notification and not actor_menu.__era_ihud_notif_hooked then
    local original_set_notification = actor_menu.set_notification

    actor_menu.set_notification = function(typ, texture, tm, snd)
        original_set_notification(typ, texture, tm, snd)
        set_pda_notification_visible(should_display_for_setting_key(KEYS.mode_pda_notification))
    end

    actor_menu.__era_ihud_notif_hooked = true
end

local function set_status_visible(visible)
    if not actor_status then return end

    local hud = actor_status.HUD
    if not (hud and hud.GetWndPos and hud.SetWndPos) then return end
    local ok, p = pcall(hud.GetWndPos, hud)
    if not (ok and p) then return end

    local parked = p.y >= OFFSCREEN_MIN_COORD

    if visible and parked then
        pcall(hud.SetWndPos, hud, vector2():set(p.x, p.y - OFFSCREEN_OFFSET))
    elseif not visible and not parked then
        pcall(hud.SetWndPos, hud, vector2():set(p.x, p.y + OFFSCREEN_OFFSET))
    end
end

local function set_minimap_visible(visible)
    local mg = ActorMenu.get_maingame()
    if not mg or not mg.UIZoneMap then return end

    mg.UIZoneMap.disabled = not visible
    -- not sure UIMotion is needed tbf
    mg.UIMotionIcon:Show(visible and true or false)
end

local function set_companion_visible(visible)
    if not (axr_companions and axr_companions.HUD) then return end

    local hud = axr_companions.HUD
    if not hud.Show then return end
    hud:Show(visible and true or false)
end

-- ===========================================================================
-- 6. Lock overlay  (our own padlock-icon UI for when the HUD is locked in place and won't disappear automatically.)
-- ===========================================================================

local LOCK_XML = "era_immersive_hud.xml"

class "UIEraIHudLock" (CUIScriptWnd)
function UIEraIHudLock:__init()
    super()
    local xml = CScriptXmlInit()
    xml:ParseFile(LOCK_XML)
    -- era_lock draws the padlock texture (ui_era_ihud_lock) straight from the xml;
    -- nothing to set at runtime (no text control on a texture-only static).
    self.label = xml:InitStatic("era_lock", self)
end

function UIEraIHudLock:__finalize() end

local lock_dialog = nil -- the live overlay (nil while hidden); reset per session in on_game_start

local function set_lock_indicator_visible(visible)
    local hud = get_hud()
    if not hud then return end

    if visible then
        if not lock_dialog then
            lock_dialog = UIEraIHudLock()
            hud:AddDialogToRender(lock_dialog)
        end
    elseif lock_dialog then
        hud:RemoveDialogToRender(lock_dialog)
        lock_dialog = nil
    end
end

-- The radiation bar (background slot + trefoil icon + progress fill) is drawn entirely by us
-- from our own textures, instead of relying on SidHUD's fill + the Minimalist HUD's baked-in
-- panel groove. This lets the whole bar -- background included -- follow mode_radiation. The
-- slot/icon statics draw first and the fill progress bar on top (same window), so the z-order
-- is guaranteed without coordinating with SidHUD's separate dialog. Slot and icon are separate
-- statics so the icon can be toggled independently to follow BHS's display mode.
class "UIEraIHudRadiation" (CUIScriptWnd)
function UIEraIHudRadiation:__init()
    super()
    local xml = CScriptXmlInit()
    xml:ParseFile(LOCK_XML) -- shares our private layout file
    self.window = xml:InitStatic("era_rad_window", self)
    self.slot   = xml:InitStatic("era_rad_window:era_rad_slot", self.window)
    self.icon   = xml:InitStatic("era_rad_window:era_rad_icon", self.window)
    self.fill   = xml:InitProgressBar("era_rad_window:era_rad_fill", self.window)
    self.fill:Show(true)
end

function UIEraIHudRadiation:__finalize() end

local rad_dialog = nil -- the live radiation-bar overlay; reset per session in on_game_start

local function ensure_rad_dialog()
    if rad_dialog then return end
    local hud = get_hud()
    if not hud then return end
    -- Guard creation: a missing texture/layout must not break the per-frame HUD logic.
    local ok, dlg = pcall(UIEraIHudRadiation)
    if not (ok and dlg) then return end
    rad_dialog = dlg
    hud:AddDialogToRender(rad_dialog)
end

-- Defined into the forward-declared local so update_radiation_reveal (above) and
-- apply_hud_visibility_logic (below) can both drive it.
apply_radiation = function()
    set_radiation_visible(false) -- we render our own bar; keep SidHUD's own bar hidden
    ensure_rad_dialog()
    if not rad_dialog then return end

    local rad = (db.actor and db.actor.radiation) or 0
    rad_dialog.fill:SetProgressPos(rad * 100) -- matches SidHUD's scale (value max = 35)

    local want = radiation_should_display()
    -- BHS's own H-key can fully hide its HUD (show_hud_type 0) even while our mod wants it
    -- shown; in that "no info" mode the radiation bar disappears too (no bar -> simple bar ->
    -- bar with icon, tracking BHS's mode). This is BHS's hide, detected as "we want BHS shown
    -- but it isn't" -- distinct from OUR mod hiding BHS (bhs_should_display() false), which is
    -- a standalone auto-reveal that keeps the bar.
    if want and bhs_should_display() and not bhs_looks_visible() then
        want = false
    end

    rad_dialog.window:Show(want)
    -- "Simplify auto-revealed bars": when shown purely because we're irradiated (not via
    -- Always-show or the hotkey), drop the background slot and leave just the fill.
    local auto_only = want and not should_display_for_setting_key(KEYS.mode_radiation)
    local show_slot = want and not (auto_only and settings_cache.minimal_auto_reveal)
    rad_dialog.slot:Show(show_slot)
    -- Trefoil icon follows BHS's mode: shown only when BHS's full body panel is up (highest
    -- info mode), OR when BHS isn't on screen at all (a standalone auto-reveal keeps the icon).
    rad_dialog.icon:Show(show_slot and (not bhs_should_display() or bhs_full_panel_shown()))
end

-- ===========================================================================
-- 7. Central dispatch
-- ===========================================================================

function apply_hud_visibility_logic()
    if not (db and db.actor) then return end

    set_lock_indicator_visible(is_hud_pinned and settings_cache.show_lock_indicator)

    apply_bhs_visibility()

    set_minimap_visible(should_display_for_setting_key(KEYS.mode_minimap))
    set_ammo_visible(ammo_should_display())
    apply_radiation()
    set_status_visible(status_reveal_active() or damage_reveal_active()
        or should_display_for_setting_key(KEYS.mode_statuses, KEYS.reveal_during_inventory))
    set_pda_messages_visible(should_display_for_setting_key(KEYS.mode_pda_messages,
        KEYS.reveal_pda_messages_during_inventory))
    set_pda_notification_visible(should_display_for_setting_key(KEYS.mode_pda_notification))
    set_companion_visible(should_display_for_setting_key(KEYS.mode_companion))
end

-- ===========================================================================
-- 8. Input & reveal triggers  (keys, per-frame update, inventory/damage/stamina)
-- ===========================================================================

local function actor_menu_on_mode_changed_callback(mode, last_mode)
    if mode == 1 then
        is_inventory_open = true
        apply_hud_visibility_logic()
    elseif last_mode == 1 then
        is_inventory_open = false
        apply_hud_visibility_logic()
    end
end

local has_applied_initial_settings = false

local function actor_on_update_callback()
    if not (db and db.actor) then return end

    if not has_applied_initial_settings then
        has_applied_initial_settings = true
        apply_hud_visibility_logic()
    end

    if settings_cache.pin_enabled and key_down_time ~= 0 and not long_press_fired then
        local threshold = (settings_cache.long_press_duration or 0.5) * 1000
        if time_global() - key_down_time >= threshold then
            long_press_fired = true
            pin_hud_from_hotkey()
        end
    end

    update_stamina_reveal()
    update_radiation_reveal()
    update_ammo_reveal()
    update_status_reveal()

    -- BHS (or another mod such as DART) can rebuild and re-show its statics after we
    -- hid them. While BHS should be hidden, re-assert the hide if it has reappeared.
    -- Unsure how performance could be affected by this at the moment.
    if not bhs_should_display() then
        local now = time_global()

        if now >= bhs_reassert_next then
            -- During a stamina-only reveal the hook lets BHS build every part shown, so check each
            -- frame to hide the non-stamina parts the instant they appear. Otherwise throttle.
            bhs_reassert_next = now + (is_stamina_showing and 0 or BHS_REASSERT_INTERVAL)
            if bhs_looks_visible() then apply_bhs_visibility() end
        end
    end

    if full_hud_timer > 0 and time_global() >= full_hud_timer then
        full_hud_timer = 0
        is_hud_showing = false
        is_hud_pinned  = false
        apply_hud_visibility_logic()
    end

    if settings_cache.reveal_bhs_on_damage then
        local hp = db.actor.health
        if last_actor_health and hp > 0 and hp < last_actor_health - 0.0293 then
            trigger_bhs_damage_reveal()
        end
        last_actor_health = hp

        local psy = get_actor_psy_health()
        if last_actor_psy_health and psy < last_actor_psy_health - DAMAGE_PSY_DROP then
            trigger_bhs_damage_reveal()
        end
        last_actor_psy_health = psy
    else
        last_actor_health     = db.actor.health
        last_actor_psy_health = get_actor_psy_health()
    end

    if bhs_reveal_on_damage_timer > 0 and time_global() >= bhs_reveal_on_damage_timer then
        bhs_reveal_on_damage_timer = 0
        apply_hud_visibility_logic()
    end

    if status_reveal_timer > 0 and time_global() >= status_reveal_timer then
        status_reveal_timer = 0
        apply_hud_visibility_logic()
    end

    -- No apply needed: update_ammo_reveal() above re-hides on the next frame.
    if ammo_fired_timer > 0 and time_global() >= ammo_fired_timer then
        ammo_fired_timer = 0
    end

    if is_hud_showing_due_to_actor_damage and (not settings_cache.reveal_bhs_on_damage
            or not settings_cache.reveal_bhs_keep_while_hurt
            or not actor_is_hurt()) then
        is_hud_showing_due_to_actor_damage = false
        apply_hud_visibility_logic()
    end
end

-- FDDA (Food/Drugs/Drinks Animations) plays item/harvest animations during which the
-- engine filters input: anim_prepare() calls game.only_allow_movekeys(true), and the
-- mutant-harvest path additionally calls level.disable_input(). While an animation is
-- live, enhanced_animations.used_item / used_monster are non-nil. Probed defensively so
-- we don't hard-depend on FDDA being installed.
local function fdda_anim_active()
    return enhanced_animations
        and (enhanced_animations.used_item or enhanced_animations.used_monster)
        and true or false
end

-- True if the configured toggle modifier (if any) is currently held.
local function toggle_modifier_held()
    local mod_id = settings_cache.toggle_modifier -- 0=none 1=shift 2=ctrl 3=alt
    if mod_id and mod_id ~= 0 and ui_mcm and ui_mcm.get_mod_key then
        return ui_mcm.get_mod_key(mod_id) and true or false
    end
    return true
end

-- Resolve the toggle key + optional modifier. Checked when the key goes down.
local function toggle_key_event_valid(dik)
    if not (db and db.actor) then return false end
    if level.main_input_receiver and level.main_input_receiver() then return false end
    if not settings_cache.toggle_key or settings_cache.toggle_key == 0 then return false end
    if dik ~= settings_cache.toggle_key then return false end
    if not toggle_modifier_held() then return false end
    return true
end

-- A quick tap: flip the HUD (or cancel an active damage reveal), honoring auto-hide.
local function toggle_hud_from_hotkey()
    is_hud_pinned = false -- a tap is never a pin; tapping while pinned unpins (hides) it

    if not is_hud_showing and (bhs_reveal_on_damage_timer > 0 or is_hud_showing_due_to_actor_damage) then
        full_hud_timer                     = 0
        bhs_reveal_on_damage_timer         = 0
        is_hud_showing_due_to_actor_damage = false
        apply_hud_visibility_logic()
        return
    end

    is_hud_showing = not is_hud_showing

    if is_hud_showing then
        full_hud_timer = settings_cache.auto_hide_enabled
            and (time_global() + (settings_cache.reveal_duration or 5) * 1000)
            or 0
    else
        full_hud_timer                     = 0
        bhs_reveal_on_damage_timer         = 0
        is_hud_showing_due_to_actor_damage = false
    end

    apply_hud_visibility_logic()
end

-- A long press: pin the HUD on, ignoring the auto-hide timer, so it stays visible
-- until the player taps the hotkey again to hide it. Fired from the per-frame check
-- in actor_on_update_callback the moment the hold passes long_press_duration.
pin_hud_from_hotkey = function()
    is_hud_showing = true
    is_hud_pinned  = true
    full_hud_timer = 0 -- no auto-hide while pinned
    apply_hud_visibility_logic()
end

local function on_key_press_callback(dik)
    if not toggle_key_event_valid(dik) then return end

    if key_down_time == 0 then
        key_down_time    = time_global()
        long_press_fired = false
    end
end

local function on_key_release_callback(dik)
    if dik ~= settings_cache.toggle_key then return end
    if not (db and db.actor) then return end

    -- During an FDDA animation (eat/drink/loot/harvest) the engine filters the key PRESS
    -- (only_allow_movekeys / disable_input), so on_key_press never ran and key_down_time
    -- is still 0 -- but the RELEASE event DOES fire. Honor that press-less release as a
    -- tap so the hotkey still toggles mid-animation. No long-press pin is possible here:
    -- with no press there was nothing to time.
    if key_down_time == 0 then
        if fdda_anim_active() and toggle_modifier_held() then
            toggle_hud_from_hotkey()
        end
        return
    end

    local pinned     = long_press_fired
    key_down_time    = 0
    long_press_fired = false

    if pinned then return end
    if level.main_input_receiver and level.main_input_receiver() then return end

    toggle_hud_from_hotkey()
end

-- ===========================================================================
-- 9. Lifecycle & callback registration
-- ===========================================================================

local function on_option_change_callback()
    reload_settings_cache()
    apply_hud_visibility_logic()
end

local function on_news_received_callback()
    if not (db and db.actor) then return end
    set_pda_messages_visible(should_display_for_setting_key(KEYS.mode_pda_messages,
        KEYS.reveal_pda_messages_during_inventory))
end

-- Arm the post-fire ammo reveal; update_ammo_reveal() shows it next frame and the
-- timer-expiry check clears it. Reuses the shared reveal_duration, like the others.
local function actor_on_weapon_fired_callback()
    if settings_cache.reveal_ammo_on_fire then
        ammo_fired_timer = time_global() + (settings_cache.reveal_duration or 5) * 1000
    end
end

-- Drop our overlay dialogs (lock + radiation bar) and rebuild them against the current HUD.
-- A plain re-apply would skip them: a non-nil stale ref looks "already shown", but it's bound
-- to the old (rebuilt) HUD instance. Used on resolution change and DART HUD refresh.
local function rebuild_lock_overlay()
    local hud = get_hud()
    if hud then
        if lock_dialog then hud:RemoveDialogToRender(lock_dialog) end
        if rad_dialog then hud:RemoveDialogToRender(rad_dialog) end
    end
    lock_dialog = nil
    rad_dialog  = nil
    apply_hud_visibility_logic()
end

local function actor_on_first_update_callback()
    -- Install here (not on_game_start): our on_game_start runs before BHS's, so
    -- BHS hasn't registered its actor_on_update yet at that point.
    install_bhs_update_hook()
    install_radiation_icon_hook()
end

function on_game_start()
    reload_settings_cache()
    has_applied_initial_settings       = false

    -- TODO: this is getting out of hand lol
    is_hud_showing                     = false
    is_inventory_open                  = false
    is_stamina_showing                 = false
    is_hud_showing_due_to_actor_damage = false
    key_down_time                      = 0
    long_press_fired                   = false
    is_hud_pinned                      = false
    lock_dialog                        = nil
    rad_dialog                         = nil
    bhs_reveal_on_damage_timer         = 0
    status_reveal_timer                = 0
    last_status_set                    = nil
    status_check_next                  = 0
    full_hud_timer                     = 0
    ammo_fired_timer                   = 0
    last_actor_health                  = nil
    last_actor_psy_health              = nil
    bhs_reassert_next                  = 0
    bhs_update_hooked                  = false
    bhs_active_suffix                  = nil
    last_radiation_visible             = nil

    RegisterScriptCallback("on_key_press", on_key_press_callback)
    RegisterScriptCallback("on_key_release", on_key_release_callback)
    RegisterScriptCallback("on_option_change", on_option_change_callback)
    RegisterScriptCallback("actor_on_update", actor_on_update_callback)
    RegisterScriptCallback("actor_on_first_update", actor_on_first_update_callback)
    RegisterScriptCallback("ActorMenu_on_mode_changed", actor_menu_on_mode_changed_callback)
    RegisterScriptCallback("on_news_received", on_news_received_callback)
    RegisterScriptCallback("actor_on_weapon_fired", actor_on_weapon_fired_callback)
    RegisterScriptCallback("on_screen_resolution_changed", rebuild_lock_overlay)

    if dart_module then
        RegisterScriptCallback("on_dart_post_refresh", rebuild_lock_overlay)
    end
end
